dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── PyInstaller ───────────────────────────────────────────────────────────────
*.app/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

