.DS_Store
.AppleDouble
.LSOverride
._*

# ── Secrets and credentials ───────────────────────────────────────────────────
.env
.env.*
*.token
*secret*
*credential*
*.key
*.pem
github_token
secrets/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

